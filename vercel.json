{
  "functions": {
    "app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    },
    "app/api/webhooks/fal/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/cleanup/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }]
}
