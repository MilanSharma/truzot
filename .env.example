# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXECUTIVE=price_...

# fal.ai
FAL_KEY=your-fal-key
FAL_WEBHOOK_SECRET=your-webhook-secret

# Resend
RESEND_API_KEY=re_...

# Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Cron & QStash
CRON_SECRET=your-cron-secret
QSTASH_TOKEN=your-qstash-token

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Sentry (optional)
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Rewardful (affiliate tracking — optional)
NEXT_PUBLIC_REWARDFUL_API_KEY=
NEXT_PUBLIC_REWARDFUL_SIGNUP_URL=https://your-campaign.getrewardful.com/signup
